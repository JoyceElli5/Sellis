# Sellis BeautySpa Environment Variables

# The contact WhatsApp number (Required for WhatsApp functionality)
# Format should include the country code without the plus sign. For example, for Ghana (+233), use 233 followed by the number.
NEXT_PUBLIC_WHATSAPP_NUMBER=233201234567

# Resend API Key for Email Notifications (Server-side ONLY, do NOT use NEXT_PUBLIC prefix)
RESEND_API_KEY=re_123456789_placeholder
